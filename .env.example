# ============================================================================
# passport-photo-service — environment variables
# Copy to .env (or load via your runtime's secret manager) and fill in.
# Production deployments should use GCP Secret Manager via Terraform — see
# terraform/terraform.tfvars.example.
# ============================================================================

# ---- Database (Cloud SQL MySQL) -------------------------------------------
# When running on Cloud Run, set INSTANCE_CONNECTION_NAME to your Cloud SQL
# socket name (project:region:instance). The app then connects via the
# /cloudsql/<INSTANCE_CONNECTION_NAME> unix socket. When unset, the app
# falls back to a TCP connection at DB_HOST:DB_PORT (useful for local dev).
INSTANCE_CONNECTION_NAME=
DB_NAME=passport_photo_db
DB_USER=appuser
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# ---- Google Cloud Storage --------------------------------------------------
STORAGE_BUCKET=your-gcs-bucket-name
# Path to your GCP service account JSON key (only required for local dev;
# Cloud Run uses the service account attached to the revision).
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/sa-key.json

# ---- Stripe ----------------------------------------------------------------
STRIPE_SECRECT_KEY=
STRIPE_WEBHOOK=

# ---- Walgreens print fulfillment API --------------------------------------
WALGREENS_API_KEY=
WALGREENS_AFF_ID=photoapi
APP_VER=1.0
DEV_INF=python,3.8
WALGREENS_PRODUCT_GROUP_ID=STDPR

# ---- Walmart fulfillment URL (read-only) ----------------------------------
WALMART_STORE_URL=https://photos3.walmart.com/order/prints-builder

# ---- Email (Microsoft Graph + SMTP fallback) ------------------------------
ADMIN_ORDER_CONFIRMATION_EMAIL=orders@yourdomain.com
CONFIRMATION_GMAIL_GOOGLE_PHOTOS=your-gmail@example.com
EMAIL_PASSWORD=
SMTP_SERVER=smtp.office365.com
SMTP_PORT=587

# ---- Azure (Microsoft Graph for transactional email) ----------------------
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ---- PayPal (sandbox + live) ----------------------------------------------
SANDBOX_PAYPAL_CLIENT_ID=
SANDBOX_PAYPAL_CLIENT_SECRET=
SANDBOX_PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
LIVE_PAYPAL_CLIENT_ID=
LIVE_PAYPAL_CLIENT_SECRET=
LIVE_PAYPAL_API_BASE=https://api-m.paypal.com

# ---- App ------------------------------------------------------------------
APP_BASE_URL=http://0.0.0.0:5001

# ---- Browser-Use (browser-automation API for Google Photos uploads) -------
BROWSER_USE_API_KEY=

# ---- Promo mode (temporary free-tier offer) -------------------------------
PROMO_MODE_ENABLED=false
PROMO_DIGITAL_ONLY=true
PROMO_HIDE_FULFILLMENT_OPTIONS=true
PROMO_BANNER_TEXT=Limited-time free digital passport photo
